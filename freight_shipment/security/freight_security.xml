<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_freight" model="ir.module.category">
        <field name="name">Freight</field>
        <field name="description">Access rights for the Freight Shipment Management application.</field>
        <field name="sequence">25</field>
    </record>

    <record id="res_groups_privilege_freight" model="res.groups.privilege">
        <field name="name">Freight</field>
        <field name="sequence">25</field>
        <field name="category_id" ref="module_category_freight"/>
    </record>

    <record id="group_freight_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_freight"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can register shipment requests, manage their cargo and move them through the delivery lifecycle.</field>
    </record>

    <record id="group_freight_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_freight"/>
        <field name="implied_ids" eval="[(4, ref('group_freight_user'))]"/>
        <field name="comment">Everything a Shipment User can do, plus configuring shipment types.</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
