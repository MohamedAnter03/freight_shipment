<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_shipment_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Shipment Order <span t-field="doc.name"/></h2>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Customer</strong>
                                <div t-field="doc.partner_id"
                                     t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Shipment Type</strong></td>
                                        <td><span t-field="doc.shipment_type_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status</strong></td>
                                        <td><span t-field="doc.state"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Requested Pickup</strong></td>
                                        <td><span t-field="doc.pickup_date"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Requested Delivery</strong></td>
                                        <td><span t-field="doc.delivery_date"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12">
                                <strong>Route:</strong>
                                <span t-field="doc.origin"/> &#8594; <span t-field="doc.destination"/>
                            </div>
                        </div>

                        <h4 class="mt-4">Cargo Items</h4>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Unit Weight (kg)</th>
                                    <th class="text-end">Unit Volume (m³)</th>
                                    <th class="text-end">Total Weight (kg)</th>
                                    <th class="text-end">Total Volume (m³)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.cargo_line_ids" t-as="line">
                                    <td><span t-field="line.description"/></td>
                                    <td class="text-end"><span t-field="line.quantity"/></td>
                                    <td class="text-end"><span t-field="line.weight"/></td>
                                    <td class="text-end"><span t-field="line.volume"/></td>
                                    <td class="text-end"><span t-field="line.total_weight"/></td>
                                    <td class="text-end"><span t-field="line.total_volume"/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" class="text-end"><strong>Totals</strong></td>
                                    <td class="text-end"><strong t-field="doc.total_weight"/></td>
                                    <td class="text-end"><strong t-field="doc.total_volume"/></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
